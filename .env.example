# Google Cloud Console -> APIs & Services -> Credentials -> OAuth client ID (Web application)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Random secret used to encrypt the session JWT. Generate with: openssl rand -base64 32
AUTH_SECRET=

# console.anthropic.com -> API Keys
ANTHROPIC_API_KEY=

# From the Neon Postgres integration (Vercel dashboard -> Storage) — Project Settings ->
# Environment Variables, or `vercel env pull .env.local` after creating the database.
DATABASE_URL=
DATABASE_URL_UNPOOLED=
